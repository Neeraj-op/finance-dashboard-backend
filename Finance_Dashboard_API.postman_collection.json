{
    "info": {
      "name": "Finance Dashboard API",
      "description": "Complete API testing for Finance Dashboard Backend",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
      {
        "name": "Authentication",
        "item": [
          {
            "name": "Register Admin User",
            "request": {
              "method": "POST",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"username\": \"admin_test\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin123!\",\n  \"password_confirm\": \"Admin123!\",\n  \"role\": \"ADMIN\"\n}"
              },
              "url": {"raw": "{{base_url}}/api/auth/register/"}
            }
          },
          {
            "name": "Register Analyst User",
            "request": {
              "method": "POST",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"username\": \"analyst_test\",\n  \"email\": \"analyst@test.com\",\n  \"password\": \"Analyst123!\",\n  \"password_confirm\": \"Analyst123!\",\n  \"role\": \"ANALYST\"\n}"
              },
              "url": {"raw": "{{base_url}}/api/auth/register/"}
            }
          },
          {
            "name": "Register Viewer User",
            "request": {
              "method": "POST",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"username\": \"viewer_test\",\n  \"email\": \"viewer@test.com\",\n  \"password\": \"Viewer123!\",\n  \"password_confirm\": \"Viewer123!\",\n  \"role\": \"VIEWER\"\n}"
              },
              "url": {"raw": "{{base_url}}/api/auth/register/"}
            }
          },
          {
            "name": "Login Admin",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "var jsonData = pm.response.json();",
                    "pm.environment.set(\"admin_token\", jsonData.access);"
                  ]
                }
              }
            ],
            "request": {
              "method": "POST",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"username\": \"admin_test\",\n  \"password\": \"Admin123!\"\n}"
              },
              "url": {"raw": "{{base_url}}/api/auth/login/"}
            }
          }
        ]
      }
    ]
  }